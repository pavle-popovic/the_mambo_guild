      "15": "5 6 7، و 1.",
      "16": "جيد جدًا.",
      "17": "سنكرّر Tres Tres.",
      "18": "هيا بنا!",
      "19": "1 2 3، داخل، خارج، تقاطع، داخل، خارج، تقاطع، داخل،\nخارج، تقاطع،",
      "20": "لوّ.",
      "21": "جيد جدًا.",
      "22": "Chassé.",
      "23": "مرة أخرى.",
      "24": "جيد جدًا.",
      "25": "سنفعلها مرة أخيرة.",
      "26": "هيا بنا!",
      "27": "و أمام، مزدوج، تقاطع،",
      "28": "و 1 2 3.",
      "29": "جيد جدًا.",
      "30": "Chassé.",
      "31": "5 6 7، و 1.",
      "32": "جيد جدًا.",
      "33": "جيد جدًا."
    },
    "el": {
