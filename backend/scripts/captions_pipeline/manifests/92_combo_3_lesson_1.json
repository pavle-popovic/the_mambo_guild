  "translations": {
    "ar": {
      "1": "مرحبًا وأهلًا بكم جميعًا في هذه التركيبة الثالثة\nمن",
      "2": "دورة المبتدئين.",
      "3": "لا أصدّق أننا قطعنا 75٪ من\nالطريق بالفعل.",
      "4": "هذا جنون. أشعر وكأننا بالأمس فقط\nكنا نقوم بـ",
      "5": "خطواتنا الأساسية.",
      "6": "يمكنك حقًا أن تهنّئ نفسك على\nوصولك إلى هذا الحد",
      "7": "وأتمنى أن تستمتع بهذه الرحلة.",
      "8": "إذًا سنأخذ كل الحركات التي\nتعلّمناها",
      "9": "حتى الآن.",
      "10": "وسنقوم بتركيبة صغيرة حولها.",
      "11": "مرة أخرى، نضع بعض الأساسيات بينها لكن\nلاحقًا نريد أن",
      "12": "نزيل الأساسيات، حسنًا؟",
      "13": "إذًا سنبدأ بخطوة أساسية.",
      "14": "سنذهب 1 2 3 والآن مع\nCrossover 6، 7.",
      "15": "سنذهب 1 2 3 مرة أخرى، 5 6 7.",
      "16": "لذا تذكّر، صدرك يجب أن يكون متجهًا\nللأعلى و",
      "17": "تحتاج حقًا إلى الالتواء هنا،",
      "18": "ثني الركبتين والذهاب مع أصابع القدم.",
      "19": "لذا تذكّر، ألوي الوركين، اثنِ\nالركبتين واخطُ مع",
      "20": "أصابع القدم.",
      "21": "تلك هي نقاطك الثلاث.",
      "22": "الآن، بعد هذا الـ Crossover، سأنتقل\nإلى",
      "23": "خطوة أساسية.",
      "24": "وسأقوم بـ Spiral Step 6، 7.",
      "25": "سأذهب 1 2 3، 4، 5.",
      "26": "ركلة 6، 7.",
      "27": "وسأضاعفها فقط.",
      "28": "لذا سأدور على الـ 1.",
      "29": "الآن تأكّد مرة أخرى، أنني درت بكامل\nجسمي و",
