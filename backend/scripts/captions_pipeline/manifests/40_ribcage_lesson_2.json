    "ar": {
      "1": "حسنًا يا شباب، أهلًا بكم في الكورس\nالثاني عن القفص الصدري.",
      "2": "هذا مهم جدًا جدًا لسالساك.",
      "3": "لأننا سنستخدم\nدوران الأضلاع.",
      "4": "هذا أبسط بكثير، أعتقد، لكثير\nمن",
      "5": "الناس،",
      "6": "لكنه حاسم حين نرقص.",
      "7": "لأن هذا يأتي تمامًا مثل\nلفّ ورك",
      "8": "الورك،",
      "9": "إلا هذه المرة.",
      "10": "ما نفعله هو أن أوراكنا ستبقى\nمستقيمة،",
      "11": "لكن جزءنا العلوي من الصدر نزولًا سيدور.",
      "12": "إذًا سنذهب من اليمين إلى اليسار،",
      "13": "من اليمين إلى اليسار،",
      "14": "إلى اليمين، إلى اليسار.",
      "15": "حسنًا، الآن لماذا هذا مهم لأنه حين\nسنذهب",
      "16": "لرقص خطوة أساسية،",
      "17": "ما سأفعله هو أنزلق صدري قليلًا حيث\nيكون",
      "18": "وزني،",
      "19": "لكن أيضًا سأنفتح قليلًا،",
      "20": "سأستخدم قليلًا من هذه الحركة\nالملتوية لـ",
      "21": "أواجه القطر المعاكس.",
      "22": "حسنًا، وهذا ما سيخلق\nخطّي هنا.",
      "23": "لأنك ترى صدري ليس هنا.",
      "24": "أنا لا أرقص.",
      "25": "لا، أنا أرقص.",
      "26": "آه، ترى؟",
      "27": "الآن، سأضع أيضًا قليلًا من الكتف\nفقط",
