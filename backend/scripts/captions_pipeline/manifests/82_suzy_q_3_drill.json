{
  "stem": "Mambo101Edited__Suzy_Q_3_Drill",
  "translations": {
    "ar": {
      "1": "حسنًا، سنبدأ بـ Crossover،\nهل أنت جاهز؟",
      "2": "هيا.",
      "3": "و، 1 2 3، تقاطع، تقاطع، تقاطع، جيد\nجدًا.",
      "4": "سنفعلها مرة أخرى، جاهز؟",
      "5": "هيا.",
      "6": "و، تقاطع، تقاطع، تقاطع،",
      "7": "إلى الأرداف، جيد جدًا.",
      "8": "الآن، سنذهب لـ spiral مفرد،\nهيا.",
      "9": "خمسة، ستة، لوّ، غيّر الزاوية، اركل،\nخطوة، ثم،",
      "10": "اركل، خطوة، خطوة، جيد جدًا.",
      "11": "لنفعلها مرة أخرى، جاهز؟",
      "12": "هيا.",
      "13": "زاوية.",
      "14": "والآن، أحدهم يسحبك.",
      "15": "5 6 7، جيد جدًا.",
      "16": "حسنًا، الآن سنذهب للخطوة\nالحلزونية.",
      "17": "هيا.",
      "18": "5 6 7، 1 2 3، أربعة، اركل، خطوة، خطوة،\nدوران.",
      "19": "1 2 3، أربعة، اركل، خطوة، خطوة، جيد جدًا.",
      "20": "والآن، لنفعلها مرة أخرى مزدوجًا.",
      "21": "و، واحد، اثنِ تلك الركبتين.",
      "22": "5 6 7، اخطُ على ركبتيك بنفسك.",
      "23": "جيد جدًا.",
      "24": "لنأخذها مرة أخرى، جاهز؟",
      "25": "سنذهب، رائع.",
      "26": "هيا مرة أخرى.",
      "27": "سنأخذها من Crossover،\nجاهز؟",
      "28": "هيا.",
      "29": "تقاطع.",
      "30": "و، اثنِ تلك الركبتين، لوّ تلك الأرداف.",
      "31": "جيد جدًا.",
      "32": "حسنًا، مرة أخرى، هيا.",
      "33": "و، لوّ، لوّ، لوّ.",
      "34": "5 6 7، جيد جدًا.",
      "35": "تذكّر أن تبقى على تلك الأصابع.",
      "36": "والآن، سنفعل الحلزون.",
      "37": "جاهز؟",
      "38": "و، 1 2 3، أربعة، 5 6 7.",
      "39": "أساسي.",
      "40": "حسنًا.",
      "41": "لنفعلها مرة أخرى.",
      "42": "فكّر بتغيير الزاوية ذاك.",
      "43": "ستة، سبعة، 1 2 3، أربعة، 5 6 7.",
      "44": "أساسي.",
      "45": "حسنًا.",
      "46": "الآن سنذهب للخطوة الحلزونية.",
      "47": "هيا.",
      "48": "ستة، سبعة، لوّ.",
      "49": "اركل، خطوة، الآن دوران.",
      "50": "اثنان، ثلاثة، أربعة.",
      "51": "جيد جدًا.",
      "52": "جرّب كل تلك الأشياء.",
      "53": "اخطُ تحت نفسك، على ذلك الدوران\nخصوصًا.",
      "54": "هيا.",
      "55": "5 6 7.",
      "56": "1 2 3، أربعة، 5 6 7.",
      "57": "الآن، 1 2 3، أربعة، 5 6 7.",
      "58": "جيد جدًا."
    },
    "el": {
      "1": "Εντάξει, θα ξεκινήσουμε με ένα\nCrossover, είσαι έτοιμος;",
      "2": "Πάμε.",
      "3": "Και, 1 2 3, διάσχιση, διάσχιση, διάσχιση, πολύ\nκαλά.",
      "4": "Θα το κάνουμε άλλη μία φορά, έτοιμος;",
      "5": "Πάμε.",
      "6": "Και, διάσχιση, διάσχιση, διάσχιση,",
      "7": "στους γοφούς, πολύ καλά.",
      "8": "Τώρα, θα πάμε για ένα μονό σπιράλ,\nπάμε.",
      "9": "Πέντε, έξι, στρίψε, άλλαξε γωνία, λάκτισε,\nβήμα, και μετά,",
      "10": "λάκτισε, βήμα, βήμα, πολύ καλά.",
      "11": "Ας το κάνουμε ξανά, έτοιμος;",
      "12": "Πάμε.",
      "13": "Γωνία.",
      "14": "Και τώρα, κάποιος σε τραβάει.",
      "15": "5 6 7, πολύ καλά.",
      "16": "Εντάξει, τώρα θα πάμε για το Σπιράλ\nΒήμα.",
      "17": "Πάμε.",
      "18": "5 6 7, 1 2 3, τέσσερα, λάκτισε, βήμα, βήμα,\nστροφή.",
      "19": "1 2 3, τέσσερα, λάκτισε, βήμα, βήμα, πολύ καλά.",
      "20": "Και τώρα, ας κάνουμε ξανά ένα διπλό.",
      "21": "Και, ένα, λύγισε αυτά τα γόνατα.",
      "22": "5 6 7, βήμα στα γόνατά σου ο ίδιος.",
      "23": "Πολύ καλά.",
      "24": "Ας το πάρουμε ξανά, έτοιμος;",
      "25": "Θα πάμε, ωραία.",
      "26": "Πάμε ξανά.",
      "27": "Θα το πάρουμε από το Crossover,\nέτοιμος;",
      "28": "Πάμε.",
      "29": "Διάσχιση.",
      "30": "Και, λύγισε αυτά τα γόνατα, στρίψε αυτούς τους γοφούς.",
      "31": "Πολύ καλά.",
      "32": "Εντάξει, άλλη μία φορά, πάμε.",
      "33": "Και, στρίψε, στρίψε, στρίψε.",
      "34": "5 6 7, πολύ καλά.",
      "35": "Θυμήσου να μένεις σε αυτά τα δάχτυλα.",
      "36": "Και τώρα, θα κάνουμε το σπιράλ.",
      "37": "Έτοιμος;",
      "38": "Και, 1 2 3, τέσσερα, 5 6 7.",
      "39": "Βασικό.",
      "40": "Εντάξει.",
      "41": "Ας το κάνουμε άλλη μία φορά.",
      "42": "Σκέψου την αλλαγή γωνίας.",
      "43": "Έξι, εφτά, 1 2 3, τέσσερα, 5 6 7.",
      "44": "Βασικό.",
      "45": "Εντάξει.",
      "46": "Τώρα θα πάμε για το Σπιράλ Βήμα.",
      "47": "Πάμε.",
      "48": "Έξι, εφτά, στρίψε.",
      "49": "Λάκτισε, βήμα, τώρα στροφή.",
      "50": "Δύο, τρία, τέσσερα.",
      "51": "Πολύ καλά.",
      "52": "Δοκίμασε όλα αυτά.",
      "53": "Βήμα κάτω από τον εαυτό σου, σε αυτή τη στροφή\nειδικά.",
      "54": "Πάμε.",
      "55": "5 6 7.",
      "56": "1 2 3, τέσσερα, 5 6 7.",
      "57": "Τώρα, 1 2 3, τέσσερα, 5 6 7.",
      "58": "Πολύ καλά."
    }
  }
